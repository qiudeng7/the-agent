{
  "name": "the-agent",
  "version": "0.5.0",
  "description": "Electron + Vite + Vue Agent Application",
  "main": "dist-electron/main/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite",
    "make": "vue-tsc && vite build && electron-forge make",
    "make:win": "vue-tsc && vite build && electron-forge make --platform=win32 --arch=x64",
    "publish": "vue-tsc && vite build && electron-forge publish",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "vue",
    "vite",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.13",
    "@electron-forge/maker-deb": "^7.8.13",
    "@electron-forge/maker-dmg": "^7.8.13",
    "@electron-forge/maker-rpm": "^7.8.13",
    "@electron-forge/maker-squirrel": "^7.8.13",
    "@electron-forge/maker-zip": "^7.8.13",
    "@electron-forge/shared-types": "^7.11.1",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.4",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@vueuse/core": "^14.2.1",
    "marked": "^17.0.5",
    "pinia": "^3.0.1",
    "unzipper": "^0.12.3",
    "vue-router": "^4.5.0"
  }
}
