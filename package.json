{
  "name": "the-agent",
  "version": "1.0.0",
  "description": "Electron + Vite + Vue Agent Application",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "vue",
    "vite",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.4",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "pinia": "^3.0.1",
    "vue-router": "^4.5.0"
  },
  "build": {
    "appId": "com.example.the-agent",
    "productName": "The Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
