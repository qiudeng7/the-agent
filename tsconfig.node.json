{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "#electron/*": ["electron/*"],
      "#agent/*": ["agent/*"]
    }
  },
  "include": ["vite.config.ts", "electron/**/*.ts", "agent/**/*.ts", "forge.config.ts"]
}
