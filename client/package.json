{
  "name": "the-agent",
  "version": "0.17.0",
  "description": "Electron + Vite + Vue Agent Application",
  "main": "dist-electron/main/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "dev": "vite",
    "make:mac": "vue-tsc && vite build && electron-forge make --arch=arm64 --platform=darwin",
    "publish:mac": "electron-forge publish --arch=arm64 --platform=darwin",
    "make:win": "vue-tsc && vite build && electron-forge make --platform=win32 --arch=x64",
    "publish:win": "electron-forge publish --arch=x64 --platform=win32"
  },
  "keywords": [
    "electron",
    "vue",
    "vite",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "@electron-forge/cli": "^7.8.13",
    "@electron-forge/maker-zip": "^7.8.13",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "dotenv": "^17.4.0",
    "electron": "^34.2.0",
    "node-7z": "^3.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.4",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@anthropic-ai/sdk": "^0.80.0",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.5",
    "mitt": "^3.0.1",
    "pinia": "^3.0.1",
    "vue-router": "^4.5.0"
  }
}
